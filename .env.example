# Copy to .env (local) or set these as environment variables in your Portainer stack.

# Signs the session cookie. Generate a long random value, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string

# Admin login for the hidden /admin area. Change the password!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Public site identity
SITE_TITLE=Portfolio

# Max size (MB) for a single uploaded image
MAX_UPLOAD_MB=25

# Where the SQLite db + uploaded images live (mount this as a volume in Docker)
DATA_DIR=data
